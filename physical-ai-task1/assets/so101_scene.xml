<?xml version="1.0" encoding="utf-8"?>
<!--
  SO101 Robot Arm - Pick and Place Scene
  Physical AI Hackathon 2026 - Task 1
  
  This XML defines a simplified SO101 6-DOF robot arm with gripper
  and a tabletop scene with a target object and placement zone.
-->
<mujoco model="so101_pick_place">
  <compiler angle="radian" meshdir="." autolimits="true"/>
  
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicit">
    <flag contact="enable"/>
  </option>
  </option>

  <visual>
    <global offwidth="1280" offheight="960"/>
  </visual>

  <default>
    <joint armature="0.1" damping="1.0" limited="true"/>
    <geom condim="4" friction="1.0 0.005 0.001" margin="0.001"/>
    <motor ctrllimited="true" ctrlrange="-1.0 1.0"/>
    <general gainprm="50 0 0" biasprm="0 -50 -2"/>
  </default>

  <asset>
    <texture type="2d" name="grid_tex" builtin="checker" width="512" height="512"
             rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="8 8" reflectance="0.1"/>
    <material name="robot_base_mat" rgba="0.2 0.2 0.2 1"/>
    <material name="robot_link_mat" rgba="0.3 0.5 0.7 1"/>
    <material name="robot_joint_mat" rgba="0.4 0.4 0.4 1"/>
    <material name="gripper_mat" rgba="0.6 0.6 0.6 1"/>
    <material name="object_mat" rgba="0.9 0.2 0.2 1"/>
    <material name="target_mat" rgba="0.2 0.9 0.2 0.4"/>
    <material name="table_mat" rgba="0.6 0.4 0.2 1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom name="floor" type="plane" size="1.0 1.0 0.01" material="grid_mat" 
          pos="0 0 0" contype="1" conaffinity="1"/>
    
    <!-- Workspace table -->
    <body name="table" pos="0.0 0.0 0.35">
      <geom name="table_top" type="box" size="0.4 0.3 0.02" material="table_mat"
            contype="1" conaffinity="1" mass="10"/>
      <!-- Table legs -->
      <geom type="cylinder" size="0.02 0.17" pos="-0.35 -0.25 -0.19" material="table_mat"/>
      <geom type="cylinder" size="0.02 0.17" pos="0.35 -0.25 -0.19" material="table_mat"/>
      <geom type="cylinder" size="0.02 0.17" pos="-0.35 0.25 -0.19" material="table_mat"/>
      <geom type="cylinder" size="0.02 0.17" pos="0.35 0.25 -0.19" material="table_mat"/>
    </body>

    <!-- ========== SO101 Robot Arm (6-DOF + Gripper) ========== -->
    <body name="base_link" pos="0.0 0.0 0.37">
      <geom name="base" type="cylinder" size="0.045 0.025" material="robot_base_mat"
            mass="0.5" contype="0" conaffinity="0"/>
      
      <!-- Joint 1: Base rotation (shoulder_pan) -->
      <body name="shoulder_pan_link" pos="0 0 0.04">
        <joint name="shoulder_pan" type="hinge" axis="0 0 1" 
               range="-3.14 3.14" damping="1.5"/>
        <geom name="shoulder_pan_geom" type="cylinder" size="0.035 0.03" 
              material="robot_joint_mat" mass="0.2"/>
        
        <!-- Joint 2: Shoulder lift -->
        <body name="shoulder_lift_link" pos="0 0 0.04">
          <joint name="shoulder_lift" type="hinge" axis="0 1 0"
                 range="-1.57 1.57" damping="1.5"/>
          <geom name="upper_arm" type="capsule" size="0.025" fromto="0 0 0 0 0 0.1"
                material="robot_link_mat" mass="0.15"/>
          
          <!-- Joint 3: Elbow -->
          <body name="elbow_link" pos="0 0 0.1">
            <joint name="elbow" type="hinge" axis="0 1 0"
                   range="-2.35 0.0" damping="1.2"/>
            <geom name="forearm" type="capsule" size="0.02" fromto="0 0 0 0 0 0.1"
                  material="robot_link_mat" mass="0.12"/>
            
            <!-- Joint 4: Wrist pitch -->
            <body name="wrist_pitch_link" pos="0 0 0.1">
              <joint name="wrist_pitch" type="hinge" axis="0 1 0"
                     range="-1.57 1.57" damping="0.8"/>
              <geom name="wrist_pitch_geom" type="cylinder" size="0.018 0.015"
                    material="robot_joint_mat" mass="0.08"/>
              
              <!-- Joint 5: Wrist roll -->
              <body name="wrist_roll_link" pos="0 0 0.03">
                <joint name="wrist_roll" type="hinge" axis="0 0 1"
                       range="-3.14 3.14" damping="0.5"/>
                <geom name="wrist_roll_geom" type="cylinder" size="0.015 0.01"
                      material="robot_joint_mat" mass="0.05"/>
                
                <!-- Gripper base -->
                <body name="gripper_base" pos="0 0 0.02">
                  <!-- Camera sensor (simulated) -->
                  <camera name="wrist_cam" pos="0 0.03 0" euler="1.57 0 0" 
                          fovy="60" mode="fixed"/>
                  <site name="gripper_center" pos="0 0 0.03" size="0.005"/>
                  
                  <!-- Left finger -->
                  <body name="left_finger" pos="0 0.01 0.02">
                    <joint name="gripper_left" type="slide" axis="0 1 0"
                           range="0 0.025" damping="2.0"/>
                    <geom name="left_finger_geom" type="box" size="0.01 0.005 0.025"
                          material="gripper_mat" mass="0.02"
                          contype="1" conaffinity="1" friction="2.0 0.01 0.001"/>
                  </body>
                  
                  <!-- Right finger -->
                  <body name="right_finger" pos="0 -0.01 0.02">
                    <joint name="gripper_right" type="slide" axis="0 -1 0"
                           range="0 0.025" damping="2.0"/>
                    <geom name="right_finger_geom" type="box" size="0.01 0.005 0.025"
                          material="gripper_mat" mass="0.02"
                          contype="1" conaffinity="1" friction="2.0 0.01 0.001"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- ========== Object to Pick ========== -->
    <body name="pick_object" pos="0.15 0.1 0.39">
      <freejoint name="object_joint"/>
      <geom name="object_geom" type="box" size="0.02 0.02 0.02" 
            material="object_mat" mass="0.05"
            contype="1" conaffinity="1" friction="1.5 0.005 0.001"/>
      <site name="object_site" size="0.005" rgba="1 0 0 1"/>
    </body>

    <!-- ========== Target Zone ========== -->
    <body name="target_zone" pos="-0.15 -0.1 0.37">
      <geom name="target_visual" type="cylinder" size="0.04 0.001" 
            material="target_mat" contype="0" conaffinity="0"/>
      <site name="target_site" size="0.005" rgba="0 1 0 1"/>
    </body>

    <!-- ========== Lighting ========== -->
    <light name="overhead" pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light name="side" pos="0.5 0.5 1.0" dir="-0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>
    
    <!-- ========== Cameras ========== -->
    <camera name="front_cam" pos="0.6 0 0.7" xyaxes="0 1 0 -0.5 0 0.86"/>
    <camera name="top_cam" pos="0 0 1.2" euler="0 0 0" mode="targetbody" target="table"/>
    <camera name="side_cam" pos="0 0.6 0.7" xyaxes="-1 0 0 0 -0.5 0.86"/>
  </worldbody>

  <!-- ========== Actuators ========== -->
  <actuator>
    <general name="act_shoulder_pan" joint="shoulder_pan" 
             gainprm="40 0 0" biasprm="0 -40 -2" ctrlrange="-3.14 3.14"/>
    <general name="act_shoulder_lift" joint="shoulder_lift" 
             gainprm="60 0 0" biasprm="0 -60 -3" ctrlrange="-1.57 1.57"/>
    <general name="act_elbow" joint="elbow" 
             gainprm="40 0 0" biasprm="0 -40 -2" ctrlrange="-2.35 0.0"/>
    <general name="act_wrist_pitch" joint="wrist_pitch" 
             gainprm="20 0 0" biasprm="0 -20 -1" ctrlrange="-1.57 1.57"/>
    <general name="act_wrist_roll" joint="wrist_roll" 
             gainprm="15 0 0" biasprm="0 -15 -0.5" ctrlrange="-3.14 3.14"/>
    <general name="act_gripper_left" joint="gripper_left" 
             gainprm="30 0 0" biasprm="0 -30 -1" ctrlrange="0 0.025"/>
    <general name="act_gripper_right" joint="gripper_right" 
             gainprm="30 0 0" biasprm="0 -30 -1" ctrlrange="0 0.025"/>
  </actuator>

  <!-- ========== Sensors ========== -->
  <sensor>
    <jointpos name="sp_shoulder_pan" joint="shoulder_pan"/>
    <jointpos name="sp_shoulder_lift" joint="shoulder_lift"/>
    <jointpos name="sp_elbow" joint="elbow"/>
    <jointpos name="sp_wrist_pitch" joint="wrist_pitch"/>
    <jointpos name="sp_wrist_roll" joint="wrist_roll"/>
    <jointpos name="sp_gripper_left" joint="gripper_left"/>
    <jointpos name="sp_gripper_right" joint="gripper_right"/>
    <framepos name="gripper_pos" objtype="site" objname="gripper_center"/>
    <framepos name="object_pos" objtype="site" objname="object_site"/>
    <framepos name="target_pos" objtype="site" objname="target_site"/>
    <touch name="left_finger_touch" site="gripper_center"/>
  </sensor>
</mujoco>
